@using System.Text
@using BlazorDeck.Components.Config.ButtonTypes
@using BlazorDeck.Components.Config.States
@using BlazorDeck.Components.ExtentionMethods
@using BlazorDeck.Services
@using Microsoft.AspNetCore.Components.Rendering
@using StreamerbotClient
@using ButtonType = BlazorDeck.Components.Config.ButtonType
@using Color = System.Drawing.Color
@inject StreamerBotClient StreamerbotClient
@implements IAsyncDisposable
@inherits DeckButtonBase
<style>


</style>

<div style="@BuildStyle()" onpointerdown="@OnPointerDown" onpointerup="@OnPointerUp"
     class="deck-button">
    @{
        <div
            style=" width: 100%; height: 100%; display: grid; background-color:@(_pressButtonState.IsHeld ? DeckButtonConfig.InteractColor : DeckButtonConfig.ForegroundColor);">
            <div style="grid-column: 1/1;grid-row: 1/1; font-size: 1rem">
                <div
                    style="width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; color: @DeckButtonConfig.TextColor;">
                    @DeckButtonConfig.Text
                </div>
            </div>

        </div>
    }
</div>

@code {

    [Parameter] public Action<Guid> OnPageSelect { get; set; }

    private PressButtonState _pressButtonState;
    private PressButtonConfig _pressButtonConfig;


    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        _pressButtonState = (PressButtonState)ButtonState;
        

        if (DeckButtonConfig.Config is PressButtonConfig config)
        {
            _pressButtonConfig = config;
        }
        else
        {
            throw new Exception("Failed to convert press button config to its type");
        }

        DeckButtonConfig.OnStateChanged += OnStateChanged;
    }

    //state has been changed by us or another device
    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private string BuildStyle()
    {
        StringBuilder sb = new();
        if (_pressButtonState.IsHeld)
        {
            sb.Append($"background-color:{DeckButtonConfig.InteractColor};");
        }
        else
        {
            sb.Append($"background-color:{DeckButtonConfig.ForegroundColor};");
        }

        return sb.ToString();
    }


    private async Task OnPointerDown(PointerEventArgs down)
    {
        if (_pressButtonState.IsOnCooldown)
        {
            _pressButtonState.IsHeld = false;
            return;
        }

        _pressButtonState.IsHeld = true;
        DeckButtonConfig.OnStateChanged?.Invoke();


        for (int i = 0; i < (_pressButtonConfig.ActivateTime); i += 100)
        {
            Console.WriteLine($"Holding :{i}");
            await Task.Delay(100);
            if (!_pressButtonState.IsHeld)
            {
                _pressButtonState.CurrentHoldTime = 0;
                DeckButtonConfig.OnStateChanged?.Invoke();
                return;
            }

            DeckButtonConfig.OnStateChanged?.Invoke();
            _pressButtonState.CurrentHoldTime += 100;
        }


        if (_pressButtonState.IsHeld)
        {
            ActivateButtonAction();
            Console.WriteLine("ACTIVATE STREAMERBOT ACTION");
            _pressButtonState.CooldownStartTime = DateTime.UtcNow;
            _pressButtonState.CooldownEndTime = DateTime.UtcNow.AddMilliseconds(_pressButtonConfig.ButtonCooldown);
            _pressButtonState.IsHeld = false;
            DeckButtonConfig.OnStateChanged?.Invoke();
        }
    }

    private void OnPointerUp(PointerEventArgs up)
    {
        _pressButtonState.IsHeld = false;
        DeckButtonConfig.OnStateChanged?.Invoke();
    }

    public async ValueTask DisposeAsync()
    {
        DeckButtonConfig.OnStateChanged -= OnStateChanged;
    }

    public override void ActivateButtonAction(params (string, object)[] args)
    {
        if (DeckButtonConfig.StreamerBotActionId != Guid.Empty)
        {
            StreamerbotClient.DoAction(DeckButtonConfig.StreamerBotActionId, args);
        }


        if (_pressButtonConfig.PageToSwapTo != Guid.Empty)
        {
            OnPageSelect?.Invoke(_pressButtonConfig.PageToSwapTo);
        }
    }

}