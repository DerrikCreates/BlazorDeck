@page "/Test"
@layout GridLayout
@rendermode @(new InteractiveServerRenderMode(false))

<style>
    .grid {
        display: grid;
        grid-template-columns: repeat(5, 10vw);
        grid-template-rows:  repeat(5, 10vw);
        grid-gap: 5px;
    }

    .cell {
        background-color: gray;
        justify-content: center;
        align-content: center;
    }

    .full-slider {
        width: 100%;
        height: 100%;
        display: flex; /* lets the slider stretch */
        align-items: center; /* optional */
    }

    .full-slider .mud-slider {
        height: 100%;
    }

    .full-slider .mud-slider-container {
        width: 100%;
        height: 100%;
    }

    .full-slider input {
        transform: rotate(90deg);
        width: auto;
        height: auto;
    }


</style>




<div style="width: 100vw;height: 100vh; display: flex; justify-content: center; align-items: center">
    <div class="grid">

        <div class="cell" style="opacity: 50%; background-color: red; grid-column: 3 / 4; grid-row:1 / 4; ">
                
    <CustomSlider></CustomSlider>
        </div>
        <div class="cell" style="grid-column: 1 / 4; grid-row:1 / 2; ">TEST</div>
    </div>
</div>


@code {

    int value;

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
    }

}