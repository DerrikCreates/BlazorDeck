@page "/"
@using System.Text.Json
@rendermode @(new InteractiveServerRenderMode(false));
@inject IJSRuntime JsRuntime;

<script>

    function getScreenSize() {
        return {
            Width: window.innerWidth,
            Height: window.innerHeight
        }
    }

    function goFullscreen() {
        document.documentElement.requestFullscreen();

    }
</script>
<style>
    body {
        background-color: #0a53be !important;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(5, 10vw);
        grid-template-rows:  repeat(5, 10vw);
        grid-gap: 5px;
    }

    .cell {
        background-color: gray;
        justify-content: center;
        align-content: center;
    }

</style>
<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>
<button onclick="@(async () =>
                 {
                     await JsRuntime.InvokeVoidAsync("goFullscreen");
                     JsonElement size = await JsRuntime.InvokeAsync<JsonElement>("getScreenSize");

                     Console.WriteLine(size);
                 })">Fullscreen
</button>

<div class="grid" style="overflow: hidden !important;
    touch-action: none !important;
    overscroll-behavior: none !important;; height: 100%">

    <CustomSlider Style="grid-column: 1 / 5; grid-row:1 / 2; " Vertical="false"></CustomSlider>
    <CustomSlider Style="grid-column: 4 / 5; grid-row:2 / 6; background-color: red " Vertical="true"></CustomSlider>
</div>





